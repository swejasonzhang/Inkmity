# Inkmity backend environment — copy to .env (local) or set these in Render's
# inkmity-api Environment tab. Replace every "your_..." placeholder; the numeric
# values below are sensible defaults you can keep or tune.

# --- Runtime ---
NODE_ENV=production
PORT=3001

# --- Database ---
MONGO_URI=your_mongodb_atlas_connection_string

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=your_stripe_secret_key            # sk_test_... in test, sk_live_... in prod
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret   # whsec_... from the /billing/webhook endpoint
# Optional: only enable in non-prod to bump tiny test charges to Stripe's minimum
STRIPE_TEST_MODE=false

# --- URLs (CORS + Stripe Connect redirects) ---
APP_URL=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# --- Images (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=Inkmity <noreply@inkmity.com>

# --- Platform economics (reasonable defaults; tune as needed) ---
PLATFORM_FEE_PCT=0.10               # 10% platform fee (bronze tier)
PLATFORM_FEE_MIN_CENTS=500          # $5.00 minimum platform fee
STUDIO_DEFAULT_COMMISSION_PCT=0.30  # 30% studio commission (overridable per artist)
BIRTHDAY_CREDIT_CENTS=1500          # $15.00 birthday credit

# --- Admin (comma-separated Clerk user IDs) ---
# Allowed to verify studios and grant credits. Set to your own Clerk ID(s).
ADMIN_CLERK_IDS=
