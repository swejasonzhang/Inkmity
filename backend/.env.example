# Inkmity backend environment variables.
# Copy to .env.development / .env.production and fill in real values.
# Vars marked [REQUIRED] are enforced at boot in production (see config/index.js missingConfig).

# ---- Core (REQUIRED in production) ----
MONGO_URI=mongodb://localhost:27017/inkmity          # [REQUIRED]
CLERK_SECRET_KEY=sk_test_xxx                          # [REQUIRED]
STRIPE_SECRET_KEY=sk_test_xxx                         # [REQUIRED]
STRIPE_WEBHOOK_SECRET=whsec_xxx                       # [REQUIRED]
APP_URL=http://localhost:5173                         # [REQUIRED in prod] used for Stripe redirect URLs

# ---- Runtime ----
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info

# ---- Auth (Clerk) ----
CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Comma-separated Clerk user IDs granted admin/moderation access
ADMIN_CLERK_IDS=
# Comma-separated Clerk user IDs hidden from discovery (live-flow test accounts)
TEST_CLERK_IDS=

# ---- Payments (Stripe) ----
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_TEST_MODE=false
PLATFORM_FEE_BASE_CENTS=1000
PLATFORM_FEE_PCT=0.05
PLATFORM_FEE_CAP_CENTS=5000
STRIPE_PROCESSING_PCT=0.029
STRIPE_PROCESSING_FLAT_CENTS=30
STUDIO_DEFAULT_COMMISSION_PCT=0.30
MAX_BOOKING_PRICE_CENTS=5000000
FINAL_PRICE_RECONSENT_PCT=0.1

# ---- Image uploads (Cloudinary) ----
# Either CLOUDINARY_URL, or the three discrete vars below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email ----
# Resend (preferred) or SMTP fallback
RESEND_API_KEY=
FROM_EMAIL=no-reply@inkmity.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ---- AI assistant (Anthropic) ----
ANTHROPIC_API_KEY=

# ---- Observability (Sentry) ----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ---- Redis / multi-instance (optional) ----
# When set, enables the Socket.io Redis adapter, a shared cache, and a shared
# rate-limit store so the API can run on >1 instance. Unset = per-instance
# in-memory state (correct for a single instance).
REDIS_URL=
# Set "true" only when running >1 instance (forces Socket.io websocket-only;
# the frontend socket client must match). Harmless at a single instance.
SOCKET_WS_ONLY=false

# ---- Rewards / misc ----
BIRTHDAY_CREDIT_CENTS=1500
USERNAME_CHANGE_COOLDOWN_DAYS=30

# ---- Rate limiting (optional overrides) ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=5
ASSISTANT_RATE_LIMIT_MAX=30

# ---- Mongo pool (optional) ----
MONGO_MAX_POOL=
MONGO_MIN_POOL=

# ---- Dev only ----
# When "true" (non-production), bypasses booking gates (permissions/waiver/onboarding)
DEV_BYPASS_GATES=false
