# Inkmity backend environment.
# Copy to .env.development (local) or .env.production (server) and fill in.
# NEVER commit a filled-in copy — only this example belongs in git.

# ---- Core (required) --------------------------------------------------------
NODE_ENV=development                       # development | production
PORT=3001
MONGO_URI=                                 # e.g. mongodb+srv://user:pass@cluster/inkmity  (use managed Mongo + backups in prod)

# Clerk auth (required)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Stripe (required — payments). Use a *production* secret key + a real webhook
# endpoint registered in the Stripe dashboard for prod.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_TEST_MODE=true                      # set false in production

# Cloudinary (required — image uploads). Either CLOUDINARY_URL OR the trio.
CLOUDINARY_URL=                            # cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# URLs / CORS (required in prod — set to your real domain)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_URL=http://localhost:3001
# APP_URL=

# ---- AI assistant (optional — route returns 503 until set) ------------------
ANTHROPIC_API_KEY=                         # sk-ant-api03-...  (console.anthropic.com)

# ---- Observability (optional — Sentry off until DSN is set) -----------------
SENTRY_DSN=                                 # https://...@oXXXX.ingest.sentry.io/XXXX (sentry.io)
SENTRY_TRACES_SAMPLE_RATE=0                # 0 = errors only (free tier); raise for perf tracing later
LOG_LEVEL=                                  # pino level: debug|info|warn|error (default: info in prod)

# ---- Email (optional — one of Resend or SMTP) -------------------------------
RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
FROM_EMAIL=Inkmity <onboarding@resend.dev>

# ---- Tuning / business config (optional — sane defaults in config/index.js) --
MONGO_MAX_POOL=20
MONGO_MIN_POOL=2
PLATFORM_FEE_BASE_CENTS=1000               # $10 base fee
PLATFORM_FEE_PCT=0.05                       # 5%
PLATFORM_FEE_CAP_CENTS=5000                # $50 cap
STRIPE_PROCESSING_PCT=0.029
STRIPE_PROCESSING_FLAT_CENTS=30
STUDIO_DEFAULT_COMMISSION_PCT=0.30
BIRTHDAY_CREDIT_CENTS=1500
USERNAME_CHANGE_COOLDOWN_DAYS=30
ADMIN_CLERK_IDS=                            # comma-separated Clerk user ids
DEV_BYPASS_GATES=false                     # dev-only; ignored in production

# Rate limiting (per IP; disabled entirely in development). Raise RATE_LIMIT_MAX
# if real users behind shared NAT hit 429s.
RATE_LIMIT_WINDOW_MS=900000                 # 15 min
RATE_LIMIT_MAX=1000                         # general API requests / window / IP
ASSISTANT_RATE_LIMIT_MAX=30                 # AI assistant messages / window / IP
AUTH_RATE_LIMIT_MAX=5                       # failed auth attempts / window / IP
