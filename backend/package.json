{
  "name": "backend",
  "version": "1.0.0",
  "description": "ForTheLoveOfTattoos",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env.production --import ./instrument.js server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env.development --import ./instrument.js\" server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns /node_modules/ /tests/scaling/",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:load": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/scaling",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@clerk/express": "^1.7.34",
    "@sentry/node": "^10.62.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "luxon": "^3.7.2",
    "mongoose": "^8.18.0",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.12",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  }
}
