{
  "name": "backend",
  "version": "1.0.0",
  "description": "ForTheLoveOfTattoos",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env.production server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env.development\" server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns /node_modules/ /tests/scaling/",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:load": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/scaling"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clerk/express": "^1.7.34",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.1.0",
    "luxon": "^3.7.2",
    "mongoose": "^8.18.0",
    "nodemailer": "^8.0.10",
    "socket.io": "^4.8.1",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.3"
  }
}
